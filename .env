# NEXT_PUBLIC_API_BASE_URL=http://192.168.1.12:4001

NEXT_PUBLIC_API_BASE_URL=https://accidentappbackend.onrender.com

# Backend env mirror for display in Next.js (client-safe copies)
NEXT_PUBLIC_PORT=4001
NEXT_PUBLIC_USER_STATE_TTL_MS=300000
NEXT_PUBLIC_ACCIDENT_HIGH_SPEED_KMH=20
NEXT_PUBLIC_ACCIDENT_STOP_SPEED_KMH=1
NEXT_PUBLIC_ACCIDENT_DROP_WINDOW_MS=5000
NEXT_PUBLIC_ACCIDENT_CONFIRM_TIMEOUT_MS=45000
NEXT_PUBLIC_HOSPITAL_CACHE_TTL_MS=300000
NEXT_PUBLIC_HOSPITAL_SEARCH_RADIUS_M=5000
NEXT_PUBLIC_HOSPITAL_LIMIT=5
# Speed above this (km/h) = red "fast" on admin
NEXT_PUBLIC_FAST_SPEED_THRESHOLD_KMH=15